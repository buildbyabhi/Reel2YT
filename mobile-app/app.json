{
  "expo": {
    "name": "Insta2YouTube",
    "slug": "mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "scheme": "instagram-to-youtube",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.mobileapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/logo.png"
      },
      "package": "com.anonymous.mobileapp"
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      [
        "expo-share-intent",
        {
          "ios": {
            "bundleId": "com.anonymous.mobileapp.ShareExtension"
          }
        }
      ],
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "19984c37-a2ae-4bed-a550-4e15174e5415"
      }
    }
  }
}
